<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Tienda Prado{% endblock %}</title>
    <!-- Google Fonts: Top-tier Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- SEO Optimization Meta Tags -->
    <meta name="description" content="Catálogo virtual interactivo. Obras maestras del Museo del Prado en reproducciones de la más alta calidad.">
    
    <style>
        :root {
            --bg-color: #0b0f19;
            --primary-accent: #8a2be2;
            --secondary-accent: #00e5ff;
        }
        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-color);
            color: #ffffff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-image: radial-gradient(circle at top right, rgba(138,43,226,0.1), transparent 40%),
                              radial-gradient(circle at bottom left, rgba(0,229,255,0.05), transparent 40%);
            background-attachment: fixed;
        }
        
        /* Navbar Glassmorphism */
        .navbar {
            background: rgba(11, 15, 25, 0.75) !important;
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            padding: 1rem 0;
        }
        .navbar-brand {
            font-weight: 800;
            background: linear-gradient(90deg, var(--primary-accent), var(--secondary-accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
        }
        
        /* Modern Input Styling */
        .search-input {
            background: rgba(255, 255, 255, 0.05) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            color: #fff !important;
            border-radius: 50px;
            padding-left: 20px;
        }
        .search-input:focus {
            box-shadow: 0 0 15px rgba(0,229,255,0.3);
            border-color: var(--secondary-accent) !important;
        }
        .btn-search {
            border-radius: 50px;
            border: 1px solid var(--secondary-accent);
            color: var(--secondary-accent);
            transition: all 0.3s;
        }
        .btn-search:hover {
            background: var(--secondary-accent);
            color: #000;
            box-shadow: 0 0 15px rgba(0,229,255,0.4);
        }

        /* Buttons & Interactions */
        .btn-gradient {
            background: linear-gradient(45deg, var(--primary-accent), var(--secondary-accent));
            border: none;
            color: #fff;
            font-weight: 600;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .btn-gradient:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(138, 43, 226, 0.3);
            color: #fff;
        }
        
        /* Animated Cards */
        .glass-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            height: 100%;
        }
        .glass-card:hover {
            transform: scale(1.04) translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
            border-color: rgba(255,255,255,0.15);
            background: rgba(255, 255, 255, 0.04);
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fs-3" href="/">🎨 Tienda Prado</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navContent">
                <form class="d-flex ms-auto mt-3 mt-lg-0 me-3" action="/buscar" method="GET">
                    <input class="form-control me-2 search-input" type="search" name="busqueda" placeholder="Lámina, Goya..." aria-label="Buscar" value="{{ busqueda }}">
                    <button class="btn btn-search px-4" type="submit">Buscar</button>
                </form>
                <div class="d-flex align-items-center mt-3 mt-lg-0">
                    {% if usuario %}
                        {% if admin %}
                        <a href="/admin/nuevo" class="btn btn-outline-warning rounded-pill px-3 me-3 text-warning border-warning flex-shrink-0" title="Herramienta de Administrador" style="transition: all 0.3s; box-shadow: 0 0 10px rgba(255,193,7,0.2);">⚡ Crear Obra</a>
                        {% endif %}
                        <span class="text-info fw-semibold me-3 d-flex align-items-center d-none d-xl-flex">
                            <span class="fs-5 me-2">👋</span> {{ usuario }}
                        </span>
                        <a href="/logout" class="btn btn-outline-danger rounded-pill px-3 me-3 flex-shrink-0" style="border-color: rgba(220,53,69,0.3); transition: all 0.3s;">Salir</a>
                    {% else %}
                        <a href="/login" class="btn btn-outline-info rounded-pill px-4 me-3" style="border-color: var(--secondary-accent);">Entrar</a>
                    {% endif %}
                    
                    <button type="button" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas" aria-controls="cartOffcanvas" class="btn btn-outline-light rounded-pill position-relative d-flex align-items-center px-3" style="border-color: rgba(255,255,255,0.2);">
                        <span class="fs-5 me-2">🛒</span> 
                        <span class="fw-semibold">Cesta</span>
                        <span id="cartBadgeCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow-sm" {% if total_carrito <= 0 %}style="display:none;"{% endif %}>
                            {{ total_carrito }}
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </nav>
    
    <main class="container flex-grow-1" style="margin-top: 120px; margin-bottom: 50px;">
        {% block content %}{% endblock %}
    </main>
    
    <!-- Carrito Offcanvas -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="cartOffcanvas" aria-labelledby="cartOffcanvasLabel" style="background-color: var(--bg-color); border-left: 1px solid rgba(255,255,255,0.1);">
        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="offcanvas-title fw-bold" id="cartOffcanvasLabel">🛒 Tu Cesta</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column">
            
            <div id="cartItemsContainer" class="flex-grow-1 overflow-auto">
                <div class="text-center text-secondary mt-5" id="cartLoadingMsg">Cargando carrito...</div>
            </div>
            
            <div class="mt-auto border-top border-secondary pt-3">
                <div class="d-flex justify-content-between mb-3 fs-5 fw-bold">
                    <span>Total General:</span>
                    <span id="cartTotalGeneral">0.00 €</span>
                </div>
                <a href="/carrito" class="btn btn-gradient w-100 py-2 rounded-pill fw-bold">Ir a Pagar</a>
            </div>
        </div>
    </div>

    <!-- Template for offcanvas item -->
    <template id="cart-item-template">
        <div class="cart-item card glass-card h-auto mb-3 p-2 bg-dark text-white border-secondary">
            <div class="d-flex align-items-center">
                <img src="" alt="Producto" class="item-img rounded" style="width: 60px; height: 60px; object-fit: cover;">
                <div class="ms-3 flex-grow-1">
                    <h6 class="mb-0 item-title text-truncate" style="max-width: 150px;"></h6>
                    <small class="text-info item-price"></small>
                </div>
                <div class="px-2 fw-bold item-quantity"></div>
                <button class="btn btn-sm btn-outline-danger btn-delete-item ms-2 rounded-circle" style="width: 32px; height: 32px; padding: 0;">🗑️</button>
            </div>
        </div>
    </template>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const cartOffcanvasEl = document.getElementById('cartOffcanvas');
            const cartItemsContainer = document.getElementById('cartItemsContainer');
            const cartTotalGeneral = document.getElementById('cartTotalGeneral');
            const cartBadgeCount = document.getElementById('cartBadgeCount');
            const template = document.getElementById('cart-item-template');

            cartOffcanvasEl.addEventListener('show.bs.offcanvas', () => {
                cartItemsContainer.innerHTML = '<div class="text-center text-secondary mt-5">Cargando carrito...</div>';
                
                fetch('/api/carrito')
                    .then(response => response.json())
                    .then(data => {
                        cartItemsContainer.innerHTML = ''; // Limpiar
                        
                        if (data.items.length === 0) {
                            cartItemsContainer.innerHTML = '<div class="text-center text-secondary mt-5">Tu carrito está vacío</div>';
                            cartTotalGeneral.textContent = '0.00 €';
                            return;
                        }
                        
                        cartTotalGeneral.textContent = data.total + ' €';
                        
                        // Iterar y clonar
                        data.items.forEach(item => {
                            const clone = document.importNode(template.content, true);
                            
                            const cartItemDiv = clone.querySelector('.cart-item');
                            
                            clone.querySelector('.item-img').src = '/public/imagenes/' + item.imagen;
                            clone.querySelector('.item-title').textContent = item.título;
                            clone.querySelector('.item-price').textContent = item.subtotal + ' €';
                            clone.querySelector('.item-quantity').textContent = 'x' + item.cantidad;
                            
                            const btnDelete = clone.querySelector('.btn-delete-item');
                            btnDelete.addEventListener('click', () => {
                                eliminarItem(item.id, cartItemDiv);
                            });
                            
                            cartItemsContainer.appendChild(clone);
                        });
                    })
                    .catch(error => {
                        console.error('Error fetching cart:', error);
                        cartItemsContainer.innerHTML = '<div class="text-center text-danger mt-5">Error al cargar el carrito</div>';
                    });
            });

            function eliminarItem(id, domNode) {
                // Hacer btn disable para prevenir doble click
                const btn = domNode.querySelector('.btn-delete-item');
                btn.disabled = true;
                
                fetch('/api/carrito/' + id, {
                    method: 'DELETE'
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        // Eliminar dinamicamente del DOM sin refrescar
                        domNode.remove();
                        
                        // Actualizar badge total_carrito global
                        if (data.newTotal > 0) {
                            cartBadgeCount.textContent = data.newTotal;
                            cartBadgeCount.style.display = 'inline-block';
                        } else {
                            cartBadgeCount.style.display = 'none';
                            cartItemsContainer.innerHTML = '<div class="text-center text-secondary mt-5">Tu carrito está vacío</div>';
                        }
                        
                        // Recalcular total? Se podria, pero el total nos lo podria dar el backend, 
                        // o lo podemos pedir de vuelta abriendo el canvas, o actualizar el endpoint para que devuelva total tambien.
                        // Para simplificar la demo abrimos de nuevo el fetch silente, o asumimos recalculación.
                        // Hagamos un refetch rapido para actualizar totales:
                        fetch('/api/carrito')
                            .then(r => r.json())
                            .then(d => {
                                cartTotalGeneral.textContent = d.total + ' €';
                            });
                    } else {
                        btn.disabled = false;
                        alert('No se pudo borrar el item.');
                    }
                })
                .catch(err => {
                    console.error(err);
                    btn.disabled = false;
                });
            }
        });
    </script>
</body>
</html>
