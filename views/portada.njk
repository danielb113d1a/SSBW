{% extends "base.njk" %}

{% block content %}
<div class="row mb-5 justify-content-center">
    <div class="col-lg-8 text-center mt-3">
        <h1 class="display-4 fw-bolder mb-3" style="background: linear-gradient(to right, #fff, #999); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Colección de Obras Maestras</h1>
        <p class="text-muted fs-5 fw-light">Lleva la excelencia del Museo del Prado a tus paredes con nuestras impresiones de máximo lujo y cuidado artístico.</p>
        
        {% if venda_exitosa %}
            <div class="alert alert-success bg-success bg-opacity-25 border-success text-white text-center rounded-pill py-3 px-4 mt-4 fw-bold shadow-lg animate__animated animate__fadeInUp">
                ✨ ¡Transacción con éxito! Gracias por tu compra en la Tienda del Prado.
            </div>
        {% endif %}

        {% if busqueda %}
            <div class="d-inline-block mt-3 px-4 py-2 rounded-pill" style="background: rgba(0,229,255,0.1); border: 1px solid rgba(0,229,255,0.3);">
                <span class="text-info fw-semibold">Resultados para: "{{ busqueda }}"</span>
            </div>
        {% endif %}
    </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4 mt-2">
    {% for producto in cards %}
    <div class="col">
        <div class="card glass-card">
            <div class="position-relative overflow-hidden" style="height: 280px; background: #000;">
                <img src="/public/imagenes/{{ producto.imagen }}" class="w-100 h-100" alt="{{ producto.título }}" style="object-fit: cover; opacity: 0.9; transition: opacity 0.3s;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.9">
            </div>
            <div class="card-body d-flex flex-column p-4">
                <h5 class="card-title fw-semibold text-truncate mb-3" title="{{ producto.título }}">{{ producto.título }}</h5>
                <div class="mt-auto d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fs-4 fw-bolder" style="color: var(--secondary-accent);">{{ producto.precio }} €</span>
                        <a href="/producto/{{ producto.id }}" class="btn btn-gradient rounded-pill px-4 btn-sm py-2">Detalle</a>
                    </div>
                    {% if admin %}
                    <div class="d-flex w-100 mt-2 pt-3 border-top justify-content-between" style="border-color: rgba(255,255,255,0.05)!important; gap: 8px;">
                        <a href="/admin/editar/{{ producto.id }}" class="btn btn-sm btn-outline-info rounded-pill flex-grow-1" style="font-weight: 500;">✏️ Editar</a>
                        <form action="/admin/borrar/{{ producto.id }}" method="POST" class="m-0 flex-grow-1" onsubmit="return confirm('¿Seguro de que deseas BORRAR permanentemente: {{ producto.título }}?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill w-100" style="font-weight: 500;">🗑️ Borrar</button>
                        </form>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    {% else %}
    <div class="col-12 p-5 text-center w-100">
        <div class="p-5 border rounded-4 d-inline-block shadow-lg" style="background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.05)!important;">
            <h2 class="text-secondary fw-light mb-3">No hay productos que mostrar</h2>
            <p class="text-muted">No se han encontrado piezas para la búsqueda proporcionada.</p>
            <a href="/" class="btn btn-outline-light mt-3 rounded-pill px-4">Limpiar búsqueda</a>
        </div>
    </div>
    {% endfor %}
</div>

<footer class="text-center py-4 mt-5 border-top text-secondary" style="border-color: rgba(255,255,255,0.05) !important; background-color: rgba(0,0,0,0.1); margin-left: -100vw; margin-right: -100vw; padding-left: 100vw; padding-right: 100vw;">
    <div class="container">
        <small class="fw-light tracking-wide">© 2026 Museo Nacional del Prado. Implementación Premium SSR.</small>
    </div>
</footer>
{% endblock %}
